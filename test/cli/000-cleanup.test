# =============================================================================
# Global Pre-Test Cleanup
#
# Runs first (alphabetically) to ensure clean state before other tests.
# Removes leftover test directories from previous runs.
# =============================================================================

# ---- Remove leaked test artifacts from project root ----
rm -f file1.txt file2.txt shared_new.txt text.txt 2>/dev/null; echo ok
<<<
>>>
ok
>>>= 0

# ---- Clean up entire test output directory and recreate it ----
rm -rf test/cli/output; mkdir -p test/cli/output; echo global cleanup done
<<<
>>>
global cleanup done
>>>= 0
