# Network Remote Tests
# Tests bit push/verify/repair to a network/cross-filesystem path.
# Uses rclone copy to batch-stage the remote and rclone purge for fast cleanup.
#
# Set BIT_TEST_NETWORK_BASE to the base path of a slow/network filesystem.
# Examples:
#   Windows RDP:  //tsclient/c/users/david
#   WSL mount:    /mnt/c/Users/david
#   NFS/SMB:      /mnt/nas/share
# The test creates a bit-testing/ subdirectory under this path.

# ---- CLEANUP ----
rm -rf test/cli/output/work_network 2>/dev/null; rclone purge "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing" 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0

# ======================================================================
# SETUP: create repo locally, batch-copy to network, add remote
# ======================================================================

mkdir -p test/cli/output/work_network
<<<
>>>
>>>= 0

cd test/cli/output/work_network && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

cd test/cli/output/work_network && echo binary data > data.bin && echo hello world > greet.txt && bit add data.bin greet.txt && bit commit -m "Initial commit"
<<<
>>> /\[main|files? changed/
>>>= 0

# Batch-copy entire repo to network (rclone batches all .bit/index/.git/ files in one pass)
mkdir -p "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing" && rclone copy test/cli/output/work_network "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing"
<<<
>>>
>>>= 0

cd test/cli/output/work_network && bit remote add origin "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing"
<<<
>>> /Remote 'origin' added/
>>>= 0

# Fetch + push to sync tracking refs (remote already has content, push is a no-op)
cd test/cli/output/work_network && bit fetch && bit push -u origin
<<<
>>> /Push complete/
>>>= 0

# ======================================================================
# TEST: Files arrived at network remote
# ======================================================================

test -f "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing/data.bin" && echo "data exists" || echo missing
<<<
>>>
data exists
>>>= 0

test -f "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing/greet.txt" && echo "greet exists" || echo missing
<<<
>>>
greet exists
>>>= 0

# ======================================================================
# TEST: bit status shows up-to-date after push
# ======================================================================

cd test/cli/output/work_network && bit status
<<<
>>> /up to date/
>>>= 0

# ======================================================================
# TEST: Modify locally, push to network
# ======================================================================

cd test/cli/output/work_network && echo updated binary > data.bin && bit add data.bin && bit commit -m "Update data"
<<<
>>> /\[main|files? changed/
>>>= 0

cd test/cli/output/work_network && bit push
<<<
>>> /Push complete/
>>>= 0

# ======================================================================
# TEST: Verify against network remote
# ======================================================================

cd test/cli/output/work_network && bit verify
<<<
>>> /\[OK\] All.*files match/
>>>= 0

# ======================================================================
# TEST: Repair from network remote
# ======================================================================

cd test/cli/output/work_network && echo corrupted > data.bin
<<<
>>>
>>>= 0

cd test/cli/output/work_network && bit repair
<<<
>>> /REPAIRED.*data\.bin/
>>>= 0

cd test/cli/output/work_network && bit verify
<<<
>>> /\[OK\] All.*files match/
>>>= 0

# ======================================================================
# CLEANUP
# ======================================================================

rm -rf test/cli/output/work_network 2>/dev/null; rclone purge "${BIT_TEST_NETWORK_BASE:-//tsclient/c/users/david}/bit-testing" 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0
