# bit --remote <name> verify tests (filesystem remotes)
# Verifies that remote verify works for filesystem remotes using the
# bundle + file scan approach.

# ---- CLEANUP ----
rm -rf test/cli/output/work_vr 2>/dev/null; rm -rf test/cli/output/remote_vr 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0

# ======================================================================
# SETUP: init, add remote, add files, commit, push
# ======================================================================

mkdir -p test/cli/output/work_vr && mkdir -p test/cli/output/remote_vr && cd test/cli/output/work_vr && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

cd test/cli/output/work_vr && bit remote add origin ../remote_vr
<<<
>>> /Remote.*added/
>>>= 0

cd test/cli/output/work_vr && echo hello > greet.txt && echo binarydata > data.bin && bit add greet.txt data.bin && bit commit -m "Add files"
<<<
>>> /\[main|files? changed/
>>>= 0

cd test/cli/output/work_vr && bit push -u origin
<<<
>>> /Push complete/
>>>= 0

# ======================================================================
# TEST: Clean verify — all files match
# ======================================================================

cd test/cli/output/work_vr && bit --remote origin verify
<<<
>>> /\[OK\] All [0-9]+ files match metadata/
>>>= 0

# ======================================================================
# TEST: Corrupted file — hash mismatch detected
# ======================================================================

cd test/cli/output/remote_vr && echo corrupted > data.bin
<<<
>>>
>>>= 0

cd test/cli/output/work_vr && bit --remote origin verify
<<<
>>>2 /\[ERROR\] Metadata mismatch.*data\.bin/
>>>= 1

# ======================================================================
# TEST: Missing file — detected
# ======================================================================

cd test/cli/output/remote_vr && rm -f greet.txt
<<<
>>>
>>>= 0

cd test/cli/output/work_vr && bit --remote origin verify
<<<
>>>2 /\[ERROR\] Missing.*greet\.txt/
>>>= 1

# ---- CLEANUP ----
rm -rf test/cli/output/work_vr 2>/dev/null; rm -rf test/cli/output/remote_vr 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0
