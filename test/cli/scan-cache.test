# Test scan cache feature - skip re-hashing unchanged files

# Setup: fresh repo
rm -rf test/cli/output/work_scancache 2>/dev/null; mkdir -p test/cli/output/work_scancache && cd test/cli/output/work_scancache && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# Create test files and add them
cd test/cli/output/work_scancache && echo test1 > file1.txt && echo test2 > file2.txt && bit add .
<<<
>>>= 0

# Verify cache directory was created
test -d test/cli/output/work_scancache/.bit/cache && echo cache exists || echo missing
<<<
>>>
cache exists
>>>= 0

# Verify cache files were created for each file
test -f test/cli/output/work_scancache/.bit/cache/file1.txt && echo file1 cached || echo missing
<<<
>>>
file1 cached
>>>= 0

# Verify cache file format contains expected fields
grep -q 'mtime:' test/cli/output/work_scancache/.bit/cache/file1.txt
<<<
>>>= 0

# Verify cache contains size field
grep -q 'size:' test/cli/output/work_scancache/.bit/cache/file1.txt
<<<
>>>= 0

# Verify cache contains hash field
grep -q 'hash:' test/cli/output/work_scancache/.bit/cache/file1.txt
<<<
>>>= 0

# Verify cache contains isText field
grep -q 'isText:' test/cli/output/work_scancache/.bit/cache/file1.txt
<<<
>>>= 0

# Save original hash for comparison
cd test/cli/output/work_scancache && grep 'hash:' .bit/cache/file1.txt
<<<
>>> /hash: md5:[a-f0-9]+/
>>>= 0

# Run add again without changes - should use cache (no errors)
cd test/cli/output/work_scancache && bit add .
<<<
>>>= 0

# Modify file1.txt
cd test/cli/output/work_scancache && echo modified content > file1.txt
<<<
>>>= 0

# Run add after modification - cache should be updated
cd test/cli/output/work_scancache && bit add .
<<<
>>>= 0

# Verify cache was updated with new hash (different from original)
cd test/cli/output/work_scancache && grep 'hash:' .bit/cache/file1.txt
<<<
>>> /hash: md5:[a-f0-9]+/
>>>= 0

# file2.txt cache should still exist (unchanged file)
test -f test/cli/output/work_scancache/.bit/cache/file2.txt && echo file2 still cached || echo missing
<<<
>>>
file2 still cached
>>>= 0

# Test cache with subdirectory
cd test/cli/output/work_scancache && mkdir -p subdir && echo subfile > subdir/nested.txt && bit add .
<<<
>>>= 0

# Verify cache was created for nested file
test -f test/cli/output/work_scancache/.bit/cache/subdir/nested.txt && echo nested cached || echo missing
<<<
>>>
nested cached
>>>= 0

# Cleanup
rm -rf test/cli/output/work_scancache 2>/dev/null
<<<
>>>= 0
