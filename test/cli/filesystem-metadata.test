<<<
>>>
no binary - GOOD
>>>= 0

# Verify: text file also NOT synced (--metadata-only skips all file sync)
test -f test/cli/output/fsmeta_flag/readme.txt && echo "text synced - BAD" || echo "no text - GOOD"
<<<
>>>
no text - GOOD
>>>= 0

# ======================================================================
