# ======================================================================

# Set up a source bit repo with both text and binary
rm -rf test/cli/output/work_fsmeta test/cli/output/work_fsmeta_b test/cli/output/fsmeta_flag 2>/dev/null; mkdir -p test/cli/output/work_fsmeta
