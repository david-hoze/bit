# Test: single repo operations (add, commit, status, binary metadata)

# Setup fresh repo
rm -rf test/cli/output/work_onerepo 2>/dev/null; mkdir -p test/cli/output/work_onerepo && cd test/cli/output/work_onerepo && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# Add text file
cd test/cli/output/work_onerepo && echo hello > test.txt && bit add test.txt
<<<
>>>
>>>= 0

# Verify text file metadata exists in .bit/index
test -f test/cli/output/work_onerepo/.bit/index/test.txt && echo metadata exists || echo missing
<<<
>>>
metadata exists
>>>= 0

# Verify content was copied to index
grep -q hello test/cli/output/work_onerepo/.bit/index/test.txt
<<<
>>>
>>>= 0

# Status: new file staged
cd test/cli/output/work_onerepo && bit status
<<<
>>> /new file:.*test\.txt/
>>>= 0

# Commit the staged file
cd test/cli/output/work_onerepo && bit commit -m "Add test.txt"
<<<
>>> /\[master|main|files? changed/
>>>= 0

# Status after commit: working tree clean
cd test/cli/output/work_onerepo && bit status
<<<
>>> /nothing to commit|working tree clean/
>>>= 0

# Add binary file
cd test/cli/output/work_onerepo && printf '\x00binary' > file.bin && bit add file.bin
<<<
>>>
>>>= 0

# Verify binary metadata exists
test -f test/cli/output/work_onerepo/.bit/index/file.bin && echo metadata exists || echo missing
<<<
>>>
metadata exists
>>>= 0

# Verify binary metadata has hash line
grep -q 'hash:' test/cli/output/work_onerepo/.bit/index/file.bin
<<<
>>>
>>>= 0

# Verify binary metadata has size line
grep -q 'size:' test/cli/output/work_onerepo/.bit/index/file.bin
<<<
>>>
>>>= 0

# Status: new binary file staged
cd test/cli/output/work_onerepo && bit status
<<<
>>> /new file:.*file\.bin/
>>>= 0

# Commit binary
cd test/cli/output/work_onerepo && bit commit -m "Add file.bin"
<<<
>>> /\[master|main|files? changed/
>>>= 0

# Add multiple files with "add ."
cd test/cli/output/work_onerepo && echo data > data.txt && echo notes > notes.txt && bit add .
<<<
>>>
>>>= 0

# Status: multiple new files staged
cd test/cli/output/work_onerepo && bit status
<<<
>>> /new file:.*data\.txt/
>>>= 0

# Commit multiple files
cd test/cli/output/work_onerepo && bit commit -m "Add data files"
<<<
>>> /\[master|main|files? changed/
>>>= 0

# Log shows commit history
cd test/cli/output/work_onerepo && bit log --oneline
<<<
>>> /Add data files/
>>>= 0

# Cleanup
rm -rf test/cli/output/work_onerepo
<<<
>>>
>>>= 0
