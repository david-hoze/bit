# =============================================================================
# Export - Convert bit repo back to plain git repo
#
# Tests: bit export (in-place), bit export <path>, error cases
# =============================================================================

# ---- CLEANUP: remove any leftover state from previous runs ----
rm -rf test/cli/output/work_export 2>/dev/null && rm -rf test/cli/output/work_export_target 2>/dev/null && rm -rf test/cli/output/work_export_nobit 2>/dev/null && rm -rf test/cli/output/work_export_copy 2>/dev/null && echo cleanup done
<<<
>>>
cleanup done
>>>= 0

# ======================================================================
# SECTION 1: IN-PLACE EXPORT
# ======================================================================

# ---- Setup: create a bit repo with history ----
mkdir -p test/cli/output/work_export && cd test/cli/output/work_export && BIT_GIT_JUNCTION=1 bit init -q && echo hello > file.txt && bit add file.txt && bit commit -m "initial-commit"
<<<
>>> /.*commit.*/
>>>= 0

# ---- Run bit export from inside the bit repo ----
cd test/cli/output/work_export && bit export
<<<
>>> /Exported bit repository to git/
>>>= 0

# ---- Verify .git directory exists ----
test -d test/cli/output/work_export/.git && echo git-exists || echo git-missing
<<<
>>>
git-exists
>>>= 0

# ---- Verify .bit directory is gone ----
test -d test/cli/output/work_export/.bit && echo bit-still-exists || echo bit-gone
<<<
>>>
bit-gone
>>>= 0

# ---- Verify git log works ----
cd test/cli/output/work_export && git log --oneline
<<<
>>> /initial-commit/
>>>= 0

# ======================================================================
# SECTION 2: EXPORT TO PATH
# ======================================================================

# ---- Create a fresh bit repo for copy export ----
mkdir -p test/cli/output/work_export_copy && cd test/cli/output/work_export_copy && BIT_GIT_JUNCTION=1 bit init -q && echo data > doc.txt && bit add doc.txt && bit commit -m "copy-test"
<<<
>>> /.*commit.*/
>>>= 0

# ---- Export to a new directory ----
cd test/cli/output/work_export_copy && bit export ../../../../test/cli/output/work_export_target
<<<
>>> /Exported bit repository to/
>>>= 0

# ---- Verify target has .git ----
test -d test/cli/output/work_export_target/.git && echo target-git-ok || echo target-git-missing
<<<
>>>
target-git-ok
>>>= 0

# ---- Verify target has the working file ----
test -f test/cli/output/work_export_target/doc.txt && echo target-file-ok || echo target-file-missing
<<<
>>>
target-file-ok
>>>= 0

# ---- Verify target does NOT have .bit ----
test -d test/cli/output/work_export_target/.bit && echo target-bit-exists || echo target-bit-gone
<<<
>>>
target-bit-gone
>>>= 0

# ---- Verify git log works in target ----
cd test/cli/output/work_export_target && git log --oneline
<<<
>>> /copy-test/
>>>= 0

# ---- Verify original bit repo is unchanged ----
test -d test/cli/output/work_export_copy/.bit && echo original-bit-ok || echo original-bit-gone
<<<
>>>
original-bit-ok
>>>= 0

# ======================================================================
# SECTION 3: ERROR CASES
# ======================================================================

# ---- Error: not a bit repo ----
mkdir -p test/cli/output/work_export_nobit && cd test/cli/output/work_export_nobit && bit export
<<<
>>>2 /not a bit repository/
>>>= 1

# ---- Error: target path already exists ----
cd test/cli/output/work_export_copy && bit export ../../../../test/cli/output/work_export_target
<<<
>>>2 /target path already exists/
>>>= 1

# ======================================================================
# CLEANUP
# ======================================================================

rm -rf test/cli/output/work_export 2>/dev/null && rm -rf test/cli/output/work_export_target 2>/dev/null && rm -rf test/cli/output/work_export_nobit 2>/dev/null && rm -rf test/cli/output/work_export_copy 2>/dev/null && echo cleanup done
<<<
>>>
cleanup done
>>>= 0
