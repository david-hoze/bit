# Device name prompt integration tests
# Tests the interactive path when BIT_USE_STDIN=1 (piped input for testing)
#
# The Windows version (test/cli/device-prompt.test) uses `subst` to create
# a virtual drive letter. This cross-platform version uses a plain filesystem
# remote instead — the device prompt logic is the same either way.

# --- Setup: create work dir, remote dir, init bit ---
rm -rf test/cli/output/work_devprompt test/cli/output/device_prompt_remote 2>/dev/null; mkdir -p test/cli/output/work_devprompt test/cli/output/device_prompt_remote && cd test/cli/output/work_devprompt && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# --- Add remote with piped device name (BIT_USE_STDIN=1) ---
cd test/cli/output/work_devprompt && echo test_device | BIT_USE_STDIN=1 bit remote add origin ../device_prompt_remote
<<<
>>> /Remote.*origin|Device.*registered/
>>>= 0

# --- Verify remote was stored ---
grep -q 'type: ' test/cli/output/work_devprompt/.bit/remotes/origin || grep -q 'device:' test/cli/output/work_devprompt/.bit/remotes/origin || grep -q 'local:' test/cli/output/work_devprompt/.bit/remotes/origin
<<<
>>>
>>>= 0

# --- Cleanup ---
rm -rf test/cli/output/work_devprompt test/cli/output/device_prompt_remote 2>/dev/null
<<<
>>>
>>>= 0
