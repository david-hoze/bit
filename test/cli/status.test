# Test: bit status

# Setup: fresh repo with one file
rm -rf test/cli/output/work_status 2>/dev/null; mkdir -p test/cli/output/work_status && cd test/cli/output/work_status && bit init && echo data > file.bin
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# Status should show untracked file
cd test/cli/output/work_status && bit status
<<<
