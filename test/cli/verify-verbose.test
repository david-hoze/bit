# bit verify verbose output tests
# Verifies that verify prints phase messages on stderr:
#   - "Collecting files... N found."
#   - "Rehashing N files (X B) for verification." (verify always re-hashes)
#   - "Comparing against committed metadata..."

# ---- CLEANUP ----
rm -rf test/cli/output/work_vv 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0

# ======================================================================
# SETUP
# ======================================================================

mkdir -p test/cli/output/work_vv && cd test/cli/output/work_vv && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# ======================================================================
# TEST: Empty repo — collecting 0 files, all cached
# ======================================================================

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Collecting files\.\.\. 0 found/
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Rehashing 0 files for verification/
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Comparing against committed metadata/
>>>= 0

# ======================================================================
# SETUP: add files and commit
# ======================================================================

cd test/cli/output/work_vv && echo hello > a.txt && echo data > b.bin && bit add a.txt b.bin && bit commit -m "Add files"
<<<
>>> /\[main|files? changed/
>>>= 0

# ======================================================================
# TEST: Verify always re-hashes (never uses cache for correctness)
# ======================================================================

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Collecting files\.\.\. 2 found/
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Rehashing 2 files/
>>>= 0

# ======================================================================
# TEST: Verify re-hashes even with cache entries present
# ======================================================================

# Delete one cache entry (verify ignores cache anyway)
cd test/cli/output/work_vv && rm -f .bit/cache/b.bin
<<<
>>>
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Rehashing 2 files/
>>>= 0

# ======================================================================
# TEST: All caches cleared — "0 cached, 2 need hashing"
# ======================================================================

cd test/cli/output/work_vv && rm -rf .bit/cache
<<<
>>>
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Rehashing 2 files/
>>>= 0

# ======================================================================
# TEST: Corrupted file — "Comparing against committed metadata..." + ERROR
# ======================================================================

cd test/cli/output/work_vv && echo corrupted > b.bin && rm -rf .bit/cache
<<<
>>>
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /Comparing against committed metadata/
>>>= 1

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /\[ERROR\] Metadata mismatch.*b\.bin/
>>>= 1

# ======================================================================
# TEST: Missing file — ERROR on stderr
# ======================================================================

# Restore b.bin to committed content first, then delete a.txt
cd test/cli/output/work_vv && echo data > b.bin && rm -f a.txt
<<<
>>>
>>>= 0

cd test/cli/output/work_vv && bit verify
<<<
>>>2 /\[ERROR\] Missing.*a\.txt/
>>>= 1

# ---- CLEANUP ----
rm -rf test/cli/output/work_vv 2>/dev/null; echo cleanup done
<<<
>>>
cleanup done
>>>= 0
