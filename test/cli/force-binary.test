# Test .bit/force-binary and .bitbinary support (gitignore-style patterns)

# Setup: fresh repo
rm -rf test/cli/output/work_forcebinary 2>/dev/null; mkdir -p test/cli/output/work_forcebinary && cd test/cli/output/work_forcebinary && bit init
<<<
>>> /.*[Ii]nitialized.*/
>>>= 0

# Create a books directory with a small UTF-8 text file
cd test/cli/output/work_forcebinary && mkdir -p books && printf 'שלום עולם\n' > books/greeting.md
<<<
>>>= 0

# Create a normal text file outside books/
cd test/cli/output/work_forcebinary && echo "normal text" > notes.txt
<<<
>>>= 0

# Test .bitbinary (shared, committed file) with books/** pattern
cd test/cli/output/work_forcebinary && echo 'books/**' > .bitbinary
<<<
>>>= 0

# Add all files
cd test/cli/output/work_forcebinary && bit add .
<<<
>>>= 0

# Commit
cd test/cli/output/work_forcebinary && bit commit -m "test bitbinary"
<<<
>>> /file.*changed/
>>>= 0

# books/greeting.md should have 2-line binary metadata (hash + size)
cd test/cli/output/work_forcebinary && wc -l < .bit/index/books/greeting.md
<<<
>>> /2/
>>>= 0

# books/greeting.md metadata should contain hash: and size: lines
cd test/cli/output/work_forcebinary && grep -c 'hash:\|size:' .bit/index/books/greeting.md
<<<
>>> /2/
>>>= 0

# notes.txt should have full text content (not binary metadata)
cd test/cli/output/work_forcebinary && cat .bit/index/notes.txt
<<<
>>> /normal text/
>>>= 0

# notes.txt should NOT have hash: metadata (it's text, not binary)
cd test/cli/output/work_forcebinary && grep -q 'hash:' .bit/index/notes.txt && exit 1 || exit 0
<<<
>>>= 0

# .bitbinary should be tracked as a text file in the index
cd test/cli/output/work_forcebinary && cat .bit/index/.bitbinary
<<<
>>> /books/
>>>= 0

# Test .bit/force-binary (local, not committed) also works
cd test/cli/output/work_forcebinary && rm .bitbinary && mkdir -p assets && echo "asset data" > assets/info.txt && echo 'assets/**' > .bit/force-binary
<<<
>>>= 0

# Clear cache and re-add
cd test/cli/output/work_forcebinary && rm -rf .bit/cache && bit add . && bit commit -m "add assets"
<<<
>>> /file.*changed/
>>>= 0

# assets/info.txt should be binary metadata
cd test/cli/output/work_forcebinary && wc -l < .bit/index/assets/info.txt
<<<
>>> /2/
>>>= 0

# Test both files together: .bitbinary + .bit/force-binary
cd test/cli/output/work_forcebinary && echo 'books/**' > .bitbinary && echo "new book" > books/chapter2.md && echo "new asset" > assets/extra.csv
<<<
>>>= 0

# Clear cache and re-add
cd test/cli/output/work_forcebinary && rm -rf .bit/cache && bit add . && bit commit -m "both patterns"
<<<
>>> /file.*changed/
>>>= 0

# books/chapter2.md matched by .bitbinary
cd test/cli/output/work_forcebinary && wc -l < .bit/index/books/chapter2.md
<<<
>>> /2/
>>>= 0

# assets/extra.csv matched by .bit/force-binary
cd test/cli/output/work_forcebinary && wc -l < .bit/index/assets/extra.csv
<<<
>>> /2/
>>>= 0

# notes.txt still text (not matched by either)
cd test/cli/output/work_forcebinary && grep -q 'hash:' .bit/index/notes.txt && exit 1 || exit 0
<<<
>>>= 0

# Without either file, files are classified normally
cd test/cli/output/work_forcebinary && rm .bitbinary .bit/force-binary && echo "new text" > books/intro.md && rm -rf .bit/cache
<<<
>>>= 0

# Add and commit
cd test/cli/output/work_forcebinary && bit add . && bit commit -m "no patterns"
<<<
>>> /file.*changed/
>>>= 0

# books/intro.md should be text (no force-binary patterns)
cd test/cli/output/work_forcebinary && grep -q 'hash:' .bit/index/books/intro.md && exit 1 || exit 0
<<<
>>>= 0

# Cleanup
rm -rf test/cli/output/work_forcebinary 2>/dev/null; true
<<<
>>>= 0
